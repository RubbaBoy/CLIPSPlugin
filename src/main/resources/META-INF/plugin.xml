<?xml version="1.0" encoding="UTF-8"?>
<idea-plugin>
    <id>is.yarr.clips</id>
    <name>CLIPS Language Support</name>
    <vendor email="adam.yarris@biamp.com" url="https://yarr.is/">Adam Yarris</vendor>
    
    <depends>com.intellij.modules.platform</depends>
    
    <extensions defaultExtensionNs="com.intellij">
        <!-- File type registration -->
        <fileType name="CLIPS" 
                  implementationClass="is.yarr.clips.CLIPSFileType"
                  fieldName="INSTANCE" 
                  language="CLIPS" 
                  extensions="clp"/>
                  
        <!-- Syntax highlighting -->
        <lang.syntaxHighlighterFactory language="CLIPS" 
                  implementationClass="is.yarr.clips.syntax.CLIPSSyntaxHighlighterFactory"/>
                  
        <!-- Parser definition -->
        <lang.parserDefinition language="CLIPS" 
                  implementationClass="is.yarr.clips.parser.CLIPSParserDefinition"/>
                  
        <!-- Editor features -->
        <lang.braceMatcher language="CLIPS" 
                  implementationClass="is.yarr.clips.editor.CLIPSBraceMatcher"/>
        <quoteHandler className="is.yarr.clips.editor.CLIPSQuoteHandler"
                  fileType="CLIPS"/>
                  
        <!-- Code completion -->
        <completion.contributor language="CLIPS" 
                  implementationClass="is.yarr.clips.completion.CLIPSCompletionContributor"/>
                  
        <!-- Reference resolution -->
        <psi.referenceContributor language="CLIPS"
                  implementation="is.yarr.clips.psi.CLIPSReferenceContributor"/>
                  
        <!-- Variable highlighting -->
        <annotator language="CLIPS"
                  implementationClass="is.yarr.clips.editor.CLIPSAnnotator"/>
                  
        <!-- Click-based highlighting -->
        <highlightUsagesHandlerFactory 
                  implementation="is.yarr.clips.editor.CLIPSHighlightUsagesHandlerFactory"/>
                  
        <!-- Ctrl+click navigation -->
        <gotoDeclarationHandler 
                  implementation="is.yarr.clips.editor.CLIPSGotoDeclarationHandler"/>

        <extendWordSelectionHandler order="first" implementation="is.yarr.clips.editor.CLIPSExtendWordSelectioner"/>
        <editorActionHandler order="first" action="EditorSelectWord" implementationClass="is.yarr.clips.editor.CLIPSSelectWordHandlerFactory"/>
    </extensions>
</idea-plugin>